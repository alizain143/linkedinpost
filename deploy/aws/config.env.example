# Copy to config.env and fill in:
#   cp deploy/aws/config.env.example deploy/aws/config.env

# SSH target (ubuntu@<EC2_PUBLIC_IP> for Ubuntu AMIs)
APP_SSH=ubuntu@YOUR_EC2_PUBLIC_IP
SSH_KEY=~/.ssh/id_ed25519

# DNS — A record must point to EC2 public IP before first deploy
API_DOMAIN=api.yourdomain.com

# Database credentials (used by Postgres container + NestJS)
POSTGRES_USER=linkedinpost
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=linkedinpost

# Vercel frontend URL (used for CORS)
FRONTEND_URL=https://your-app.vercel.app
