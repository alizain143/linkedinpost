# Chrome Web Store API credentials for ./deploy/extension/deploy.sh
# Setup: https://developer.chrome.com/docs/webstore/using-api/

# Extension ID from Chrome Web Store Developer Dashboard (after first listing)
EXTENSION_ID=

# OAuth client (Google Cloud Console → APIs → Chrome Web Store API → Credentials)
CLIENT_ID=
CLIENT_SECRET=

# Refresh token from OAuth flow with scope https://www.googleapis.com/auth/chromewstore
REFRESH_TOKEN=
