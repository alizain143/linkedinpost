# Database
DATABASE_URL=postgresql://user@localhost:5432/linkedinpost?schema=public

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Redis (async jobs)
REDIS_URL=redis://localhost:6379
GENERATION_QUEUE_CONCURRENCY=2

# OpenAI
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4

# Google Gemini (image generation)
GEMINI_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image
MEDIA_GENERATION_MOCK=false

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3001/v1/linkedin/oauth/callback
LINKEDIN_PUBLISH_MOCK=false
LINKEDIN_API_VERSION=202601

# Clerk
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PROFILE_IMAGES=
R2_BUCKET_POST_MEDIA=
R2_PUBLIC_PROFILE_URL=
R2_PUBLIC_POST_MEDIA_URL=

# Firebase FCM (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@linkedinpost.ai

# Billing — XPay (amounts in cents: 999 = $9.99)
XPAY_PUBLIC_KEY=
XPAY_PRIVATE_KEY=
XPAY_WEBHOOK_SECRET=
XPAY_CURRENCY=USD
XPAY_AMOUNT_STARTER=999
XPAY_AMOUNT_PRO=1999
XPAY_AMOUNT_AGENCY=6999
XPAY_SUBSCRIPTION_CYCLE_COUNT=120
