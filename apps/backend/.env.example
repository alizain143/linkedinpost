# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/linkedinpost?schema=public

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
APPROVAL_LINK_EXPIRY_DAYS=14

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# OpenAI (text generation — default model: gpt-5.4 standard tier)
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.4

# Redis (required for AI Council async jobs)
REDIS_URL=redis://localhost:6379
GENERATION_QUEUE_CONCURRENCY=2

# AI Council
COUNCIL_PASS_SCORE=90
COUNCIL_MAX_TEXT_REVISIONS=1
COUNCIL_MAX_MEDIA_REGENS=1

# Scheduling
SCHEDULE_MIN_LEAD_MINUTES=15
SCHEDULE_MAX_DAYS=90

# LinkedIn publish — per-workspace OAuth (required for multiple client profiles)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3001/v1/linkedin/oauth/callback
LINKEDIN_PUBLISH_MOCK=true
LINKEDIN_API_VERSION=202601

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PROFILE_IMAGES=profile-images
R2_BUCKET_POST_MEDIA=post-media
R2_PUBLIC_PROFILE_URL=
R2_PUBLIC_POST_MEDIA_URL=
# Browser uploads PUT directly to R2 presigned URLs — buckets need CORS:
# npm run r2:configure-cors

# XPay billing (Slice 18)
XPAY_PUBLIC_KEY=
XPAY_PRIVATE_KEY=
XPAY_WEBHOOK_SECRET=
XPAY_CURRENCY=USD
XPAY_AMOUNT_STARTER=900
XPAY_AMOUNT_PRO=1900
XPAY_AMOUNT_AGENCY=4900
XPAY_SUBSCRIPTION_CYCLE_COUNT=120
# XPAY_API_BASE_URL=https://api.xpaycheckout.com
MEDIA_GENERATION_MOCK=true
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image

# Notifications (Resend email + Firebase FCM web push)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_VAPID_KEY=
