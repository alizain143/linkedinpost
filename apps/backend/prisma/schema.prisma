generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DocumentStatus {
  pending
  attached
}

enum DocumentPurpose {
  profile
}

enum WorkspaceMemberRole {
  owner
  editor
  viewer
}

enum UserPlan {
  free
  starter
  pro
  agency
}

enum WorkspaceType {
  personal
  client
}

enum ContentGoal {
  build_authority
  generate_leads
  grow_audience
}

enum PostPackageStatus {
  draft
  text_generating
  text_reviewing
  awaiting_media_selection
  media_generating
  ready_for_approval
  approved
  scheduled
  publishing
  published
  failed
}

enum PostSource {
  manual
  calendar
  autopilot
  generation
}

enum AutopilotApprovalMode {
  require_approval
  auto_schedule
}

enum PostType {
  personal_story
  list_post
  how_to
  contrarian_take
  hot_take
  case_study
  question_post
  framework
  myth_buster
  prediction
  behind_the_scenes
  comparison
}

enum CreditTransactionType {
  generation
  council
  media
  calendar
  autopilot
  content_profile
  adjustment
}

enum GenerationJobStatus {
  pending
  running
  completed
  failed
}

enum GenerationJobType {
  quick_draft
  quick_draft_single
  revise_draft
  council
  calendar
  media
}

enum ChangesApplyMode {
  review_first
  auto_apply
}

enum PostMediaType {
  quote_card
  branded_quote_card
  stat_highlight
  tip_card
  infographic
  photo_illustration
  generated
  template
}

enum MediaMode {
  freestyle
  template
}

enum MediaFormat {
  single
  carousel
}

enum CouncilAgentRole {
  writer
  reviewer
  editor
  image_scout
  media_creator
  media_reviewer
}

enum CouncilEventStatus {
  running
  completed
  failed
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  incomplete
  unpaid
}

enum NotificationType {
  generation_complete
  post_ready_for_approval
  client_approved
  client_requested_changes
  publish_succeeded
  publish_failed
  weekly_content_reminder
  product_update
}

enum NotificationDeliveryChannel {
  email
  push
}

enum NotificationDeliveryStatus {
  pending
  sent
  failed
}

enum PushDevicePlatform {
  web
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  clerkId                 String    @unique
  email                   String    @unique
  firstName               String?
  lastName                String?
  phone                   String?
  profileDocumentId       String?   @unique @db.Uuid
  profileImageUrl         String?
  timezone                String    @default("America/New_York")
  emailWeeklyReminders    Boolean   @default(true)
  emailGenerationComplete Boolean   @default(true)
  emailProductUpdates     Boolean   @default(false)
  emailPublishAlerts      Boolean   @default(true)
  pushEnabled             Boolean   @default(true)
  plan                    UserPlan  @default(free)
  toursSeen               Json?
  lastAcknowledgedPlan    UserPlan?
  linkedInMemberId        String?
  linkedInProfileSyncedAt DateTime? @db.Timestamptz(6)
  linkedInProfile         Json?
  createdAt               DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt               DateTime? @db.Timestamptz(6)

  profileDocument      Document?         @relation("UserProfileDocument", fields: [profileDocumentId], references: [id], onDelete: SetNull)
  documents            Document[]        @relation("UserDocuments")
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  creditTransactions   CreditTransaction[]
  generationJobs       GenerationJob[]
  subscription         Subscription?
  createdApprovalTokens ApprovalToken[] @relation("ApprovalTokenCreator")
  notifications         Notification[]
  pushDeviceTokens      PushDeviceToken[]

  @@map("users")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @unique @db.Uuid
  xpayCustomerId     String?            @unique
  xpaySubscriptionId String?            @unique
  plan               UserPlan?
  status             SubscriptionStatus @default(incomplete)
  cancelAtPeriodEnd  Boolean            @default(false)
  currentPeriodStart DateTime?          @db.Timestamptz(6)
  currentPeriodEnd   DateTime?          @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum BillingWebhookEventStatus {
  pending
  processed
  failed
}

model BillingWebhookEvent {
  id           String                    @id
  type         String
  status       BillingWebhookEventStatus @default(pending)
  errorMessage String?
  processedAt  DateTime                  @default(now()) @db.Timestamptz(6)

  @@map("billing_webhook_events")
}

model Document {
  id              String                  @id @default(uuid()) @db.Uuid
  userId          String                  @db.Uuid
  status          DocumentStatus          @default(pending)
  filename        String
  mimeType        String
  sizeBytes       BigInt
  storageKey      String
  storageBucket   String
  purpose         DocumentPurpose
  uploadExpiresAt DateTime                @db.Timestamptz(6)
  attachedAt      DateTime?               @db.Timestamptz(6)
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                @updatedAt @db.Timestamptz(6)

  user           User  @relation("UserDocuments", fields: [userId], references: [id], onDelete: Cascade)
  profileForUser User? @relation("UserProfileDocument")

  @@index([userId])
  @@index([status, createdAt])
  @@map("documents")
}

model Workspace {
  id                     String           @id @default(uuid()) @db.Uuid
  name                   String
  type                   WorkspaceType    @default(personal)
  ownerId                String           @db.Uuid
  changesApplyMode       ChangesApplyMode @default(review_first)
  defaultMediaMode       MediaMode        @default(freestyle)
  defaultMediaTemplateId String?          @db.Uuid
  linkedInClerkExternalAccountId String?
  linkedInMemberId               String?
  linkedInProfileName            String?
  linkedInProfile                Json?
  linkedInProfileSyncedAt        DateTime?        @db.Timestamptz(6)
  linkedInAccessToken            String?
  linkedInRefreshToken           String?
  linkedInTokenExpiresAt         DateTime?        @db.Timestamptz(6)
  createdAt              DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime         @updatedAt @db.Timestamptz(6)
  deletedAt              DateTime?        @db.Timestamptz(6)

  owner                User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members              WorkspaceMember[]
  contentProfiles      ContentProfile[]
  postPackages         PostPackage[]
  generationJobs       GenerationJob[]
  autopilotConfig      AutopilotConfig?
  notifications        Notification[]
  mediaTemplates       MediaTemplate[]
  defaultMediaTemplate MediaTemplate?    @relation("WorkspaceDefaultMediaTemplate", fields: [defaultMediaTemplateId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([ownerId, type, deletedAt])
  @@map("workspaces")
}

model AutopilotConfig {
  id                  String                @id @default(uuid()) @db.Uuid
  workspaceId         String                @unique @db.Uuid
  contentProfileId    String?               @db.Uuid
  dayProfileOverrides Json?
  approvalMode        AutopilotApprovalMode @default(require_approval)
  enabled             Boolean               @default(false)
  postingDays         Int[]                 @default([1, 3, 4, 5, 7])
  postingTime         String                @default("09:00")
  lastPillarIndex     Int                   @default(0)
  lastRunDateKey      String?
  createdAt           DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime              @updatedAt @db.Timestamptz(6)
  deletedAt           DateTime?             @db.Timestamptz(6)

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentProfile ContentProfile? @relation(fields: [contentProfileId], references: [id], onDelete: SetNull)

  @@index([enabled])
  @@index([workspaceId, deletedAt])
  @@map("autopilot_configs")
}

model WorkspaceMember {
  workspaceId String @db.Uuid
  userId      String @db.Uuid
  role        WorkspaceMemberRole @default(owner)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([workspaceId, userId])
  @@map("workspace_members")
}

model ContentProfile {
  id                     String      @id @default(uuid()) @db.Uuid
  workspaceId            String      @db.Uuid
  name                   String
  roleTitle              String?
  industry               String?
  targetAudience         String?
  contentGoal            ContentGoal @default(build_authority)
  preferredTone          String?
  brandPrimary           String?
  brandAccent            String?
  offerDescription       String?
  writingSample          String?     @db.Text
  avoidWords             String?
  isDefault              Boolean     @default(false)
  defaultMediaTemplateId String?     @db.Uuid
  createdAt              DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt              DateTime?   @db.Timestamptz(6)

  workspace            Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pillars              ContentPillar[]
  posts                PostPackage[]
  autopilotConfigs     AutopilotConfig[]
  defaultMediaTemplate MediaTemplate?  @relation("ContentProfileDefaultMediaTemplate", fields: [defaultMediaTemplateId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
  @@map("content_profiles")
}

model MediaTemplate {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  name        String
  description String?
  width       Int       @default(1080)
  height      Int       @default(1080)
  layout      Json
  isSystem    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  workspace                   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  posts                       PostPackage[]
  workspaceDefaults           Workspace[]      @relation("WorkspaceDefaultMediaTemplate")
  contentProfileDefaults      ContentProfile[] @relation("ContentProfileDefaultMediaTemplate")

  @@index([workspaceId, deletedAt])
  @@map("media_templates")
}

model ContentPillar {
  id               String @id @default(uuid()) @db.Uuid
  contentProfileId String @db.Uuid
  name             String
  sortOrder        Int    @default(0)

  contentProfile ContentProfile @relation(fields: [contentProfileId], references: [id], onDelete: Cascade)

  @@unique([contentProfileId, name])
  @@index([contentProfileId])
  @@map("content_pillars")
}

model PostPackage {
  id               String            @id @default(uuid()) @db.Uuid
  workspaceId      String            @db.Uuid
  contentProfileId String?           @db.Uuid
  hook             String
  body             String?           @db.Text
  cta              String?
  tags             String[]          @default([])
  topic            String?
  postType            PostType?
  tone                String?
  pillar              String?
  mediaCustomPrompt   String?           @db.Text
  mediaMode           MediaMode?
  mediaFormat         MediaFormat       @default(single)
  carouselSlideCount  Int?
  mediaTemplateId     String?           @db.Uuid
  source              PostSource        @default(manual)
  status           PostPackageStatus @default(draft)
  score            Int?
  scheduledAt      DateTime?         @db.Timestamptz(6)
  publishedAt      DateTime?         @db.Timestamptz(6)
  linkedInPostId   String?
  linkedInPostUrl  String?
  publishErrorCode String?
  publishErrorMessage String?        @db.Text
  publishAttemptedAt DateTime?      @db.Timestamptz(6)
  submittedForApprovalAt DateTime?   @db.Timestamptz(6)
  approvalFeedback String?           @db.Text
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?         @db.Timestamptz(6)

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentProfile ContentProfile? @relation(fields: [contentProfileId], references: [id], onDelete: SetNull)
  mediaTemplate  MediaTemplate?  @relation(fields: [mediaTemplateId], references: [id], onDelete: SetNull)
  versions       PostVersion[]
  generationJobs GenerationJob[]
  media          PostMedia[]
  approvalTokens ApprovalToken[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, updatedAt])
  @@index([workspaceId, scheduledAt])
  @@index([workspaceId, deletedAt])
  @@map("post_packages")
}

model PostVersion {
  id            String   @id @default(uuid()) @db.Uuid
  postPackageId String   @db.Uuid
  versionNumber Int
  hook          String?
  body          String?  @db.Text
  cta           String?
  tags          String[] @default([])
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  postPackage PostPackage @relation(fields: [postPackageId], references: [id], onDelete: Cascade)

  @@unique([postPackageId, versionNumber])
  @@index([postPackageId])
  @@map("post_versions")
}

model PostMedia {
  id              String        @id @default(uuid()) @db.Uuid
  postPackageId   String        @db.Uuid
  generationJobId String?       @db.Uuid
  mediaType       PostMediaType
  storageKey      String
  storageBucket   String
  mimeType        String
  sizeBytes       Int
  altText         String
  sortOrder       Int           @default(0)
  metadata        Json?
  archivedAt      DateTime?     @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)

  postPackage   PostPackage    @relation(fields: [postPackageId], references: [id], onDelete: Cascade)
  generationJob GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  @@index([postPackageId])
  @@index([postPackageId, archivedAt])
  @@index([generationJobId])
  @@map("post_media")
}

model CreditTransaction {
  id              String                @id @default(uuid()) @db.Uuid
  userId          String                @db.Uuid
  generationJobId String?               @db.Uuid
  amount          Int
  type            CreditTransactionType
  reason          String?
  createdAt       DateTime              @default(now()) @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationJob GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)

  @@unique([generationJobId, type])
  @@index([userId, createdAt])
  @@index([generationJobId])
  @@map("credit_transactions")
}

model GenerationJob {
  id              String              @id @default(uuid()) @db.Uuid
  workspaceId     String              @db.Uuid
  userId          String              @db.Uuid
  type            GenerationJobType
  status          GenerationJobStatus @default(pending)
  flowId          String
  promptVersion   String              @default("v1")
  model           String?
  input           Json
  result          Json?
  errorCode       String?
  errorMessage    String?
  inputTokens     Int?
  outputTokens    Int?
  creditCost      Int                 @default(1)
  creditCharged   Boolean             @default(false)
  postPackageId   String?             @db.Uuid
  revisionCount   Int                 @default(0)
  mediaRegenCount Int                 @default(0)
  finalScore      Int?
  currentStep     String?
  progress        Json?
  createdAt       DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @db.Timestamptz(6)
  completedAt     DateTime?           @db.Timestamptz(6)
  deletedAt       DateTime?           @db.Timestamptz(6)

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  postPackage        PostPackage?        @relation(fields: [postPackageId], references: [id], onDelete: SetNull)
  councilEvents      CouncilEvent[]
  media              PostMedia[]
  creditTransactions CreditTransaction[]

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, deletedAt])
  @@index([postPackageId])
  @@map("generation_jobs")
}

model CouncilEvent {
  id              String             @id @default(uuid()) @db.Uuid
  generationJobId String             @db.Uuid
  agentRole       CouncilAgentRole
  stepOrder       Int
  revisionAttempt Int                @default(1)
  status          CouncilEventStatus
  label           String
  output          Json?
  scores          Json?
  model           String?
  inputTokens     Int?
  outputTokens    Int?
  errorCode       String?
  errorMessage    String?
  startedAt       DateTime           @default(now()) @db.Timestamptz(6)
  completedAt     DateTime?          @db.Timestamptz(6)
  durationMs      Int?

  generationJob GenerationJob @relation(fields: [generationJobId], references: [id], onDelete: Cascade)

  @@index([generationJobId, stepOrder])
  @@map("council_events")
}

model ApprovalToken {
  id            String    @id @default(uuid()) @db.Uuid
  postPackageId String    @db.Uuid
  tokenHash     String    @unique
  expiresAt     DateTime  @db.Timestamptz(6)
  revokedAt     DateTime? @db.Timestamptz(6)
  usedAt        DateTime? @db.Timestamptz(6)
  createdById   String    @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  postPackage PostPackage @relation(fields: [postPackageId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ApprovalTokenCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([postPackageId])
  @@index([postPackageId, revokedAt, usedAt])
  @@map("approval_tokens")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @db.Uuid
  workspaceId String?          @db.Uuid
  type        NotificationType
  title       String
  body        String
  actionUrl   String?
  entityType  String?
  entityId    String?          @db.Uuid
  metadata    Json?
  dedupeKey   String?          @unique
  readAt      DateTime?        @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  deliveries NotificationDelivery[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, readAt])
  @@map("notifications")
}

model PushDeviceToken {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @db.Uuid
  token      String             @unique
  platform   PushDevicePlatform @default(web)
  userAgent  String?
  lastSeenAt DateTime           @default(now()) @db.Timestamptz(6)
  revokedAt  DateTime?          @db.Timestamptz(6)
  createdAt  DateTime           @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_device_tokens")
}

model NotificationDelivery {
  id             String                      @id @default(uuid()) @db.Uuid
  notificationId String                      @db.Uuid
  channel        NotificationDeliveryChannel
  status         NotificationDeliveryStatus  @default(pending)
  providerId     String?
  error          String?                     @db.Text
  createdAt      DateTime                    @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                    @updatedAt @db.Timestamptz(6)

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, channel])
  @@map("notification_deliveries")
}
